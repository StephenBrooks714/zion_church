<!doctype html>
<html lang="en">
<%- include('layouts/head') -%>
<body>
<header>
    <%- include('layouts/navBar') -%>
</header>
<style>
    input {
        border: 1px #ccc solid;
    }
    textarea {
        border: 1px #ccc solid;
    }
</style>
<main>
    <section class="container" style="margin-top: 140px; margin-bottom: 90px;">
        <div class="row justify-content-center align-items-center">
            <div class="col-lg-10">
                <h1 class="mb-4">New Post Upload</h1>
                <form action="/store/healthy/data" method="post" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="title" name="title" class="form-control" />
                                <label class="form-label" for="title">Post Title</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="summary" name="summary" class="form-control" />
                                <label class="form-label" for="summary">Post Summary</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="time" name="time" class="form-control" />
                                <label class="form-label" for="time">Time From</label>
                            </div>
                        </div>
<!--                       2nd section -->
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="time2" name="time2" class="form-control" />
                                <label class="form-label" for="time2">Time To</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="date" name="date" class="form-control" />
                                <label class="form-label" for="date">Date From</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="date2" name="date2" class="form-control" />
                                <label class="form-label" for="date2">Date To</label>
                            </div>
                        </div>
                        <div class="col-12 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <textarea name="body" id="body" class="form-control" rows="9"></textarea>
                                <label class="form-label" for="body">Content Body</label>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" name="day" id="day" class="form-control">
                                <label class="form-label" for="day">What Day?</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="url" id="meetingUrl" name="meetingUrl" class="form-control" />
                                <label class="form-label" for="meetingUrl">Optional Meeting Link</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="url" id="payUrl" name="payUrl" class="form-control" />
                                <label class="form-label" for="payUrl">Optional Payment Link</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="location" name="location" class="form-control" />
                                <label class="form-label" for="location">Where To Meet</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="description" name="description" class="form-control" />
                                <label class="form-label" for="description">Our Description</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="guest" name="guest" class="form-control" />
                                <label class="form-label" for="guest">Our Guest(s) - optional</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div data-mdb-input-init class="form-outline">
                                <input type="text" id="additionalHost" name="additionalHost" class="form-control" />
                                <label class="form-label" for="additionalHost">Additional Host(s) - optional</label>
                            </div>
                        </div>
                        <div class="col-12 mb-3">
                            <div data-mdb-input-init class="form-outline mb-4">
                                <textarea name="comments" id="comments" class="form-control" rows="3"></textarea>
                                <label class="form-label" for="comments">Content Comments</label>
                            </div>
                            <button type="submit" class="btn btn-outline-success">Submit</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </section>
</main>

<!-- MDB -->
<%- include('layouts/footer') -%>
</body>
</html>