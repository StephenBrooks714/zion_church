<% if(foodItem != "") { %>
    <% for(i=0; i < foodItem.length; i++) {%>
<article class="row justify-content-lg-start flex-row-reverse justify-content-center text-lg-start mb-5 pb-2">

        <div class="col-lg-5 mb-lg-0 mb-3">
                <img src="/assets/church_image.png" class="img-fluid h-100 w-100" alt="<%= foodItem[i].title %>">
        </div>
        <div class="col-lg-7 mb-lg-0 mb-3">
            <div class="row">
                <div class="col-md-6">
                    <p class="h5 mb-2 text-info fw-bold"><%= foodItem[i].title %></p>
                    <hr class="w-25">
                    <p>
                        <%= foodItem[i].description %>
                    </p>
                    <address>
                        <%= foodItem[i].location %>
                    </address>
                    <a href="/foodPantry" class="btn btn-outline-primary rounded-pill">Visit Food Pantry</a>
                    <% if(loggedIn) { %>
                        <a href="/delete/food/<%= foodItem[i]._id %>" class="btn btn-outline-warning rounded-pill">Delete</a>
                    <% } %>
                </div>
                <div class="col-md-6">
                    <p>
                        <strong>Contact Person:</strong> <%= foodItem[i].contactName %>
                    </p>
                    <email>
                        <strong>Contact Email:</strong> <%= foodItem[i].contactEmail %>
                    </email>
                    <p>
                        Starting on <%= foodItem[i].startDate %>, from <%= foodItem[i].startTime %> to <%= foodItem[i].endTime %>
                    </p>
                </div>
            </div>
        </div>

</article>
    <% } %>
<% } %>
<div id="about"></div>