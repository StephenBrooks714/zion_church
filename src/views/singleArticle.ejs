<!doctype html>
<html lang="en">
<%- include('layouts/head') -%>
<body>
<header class="mb-9">
    <%- include('layouts/navBar') -%>
</header>

<main>
    <section class="container my-5 py-5">
        <div class="row justify-content-center align-items-center">
            <div class="col-lg-12">
                <p class="lead"><%= post.summary %></p>
                <h1 class="mt-0 text-primary fw-bold"><%= post.title %></h1>
                <p>
                    <strong>From:</strong> <%= post.date %> & <%= post.time %>, <strong>TO: </strong>
                    <%= post.date2 %> & <%= post.time2 %>
                </p>
                <p class="lead">
                    <%= post.body %>
                </p>
                <p class="lead">
                    It's happening on <%= post.day %>, & also <%= post.comments %>
                </p>
                <p class="lead">
                    <%= post.description %>
                </p>
            </div>
        </div>
    </section>
</main>

<!-- MDB -->
<%- include('layouts/footer') -%>
</body>
</html>