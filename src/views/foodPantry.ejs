<!doctype html>
<html lang="en">
<%- include('layouts/head') -%>
<body>
<header>
    <%- include('layouts/navBar') -%>
    <!-- Background image -->
    <div
            class="p-5 text-center bg-image"
            style="
              background-image: url('/assets/food_pantry.png');
              height: 500px;
              "
    ></div>
    <!-- Background image -->

    <div class="container">
        <div
                class="card mx-4 mx-md-5 text-center shadow-5-strong"
                style="
                margin-top: -170px;
                background: hsla(0, 0%, 100%, 0.7);
                backdrop-filter: blur(30px);
                "
        >
            <div class="card-body px-4 py-5 px-lg-3">
                <h1 class="display-3 fw-bold ls-tight mb-4">
                    AME Zion Church <br />
                    <span class="text-primary">Food Pantry</span>
                </h1>

            </div>
        </div>
    </div>
</header>

<main>
    <section class="container" style="margin-top: 70px; margin-bottom: 70px;">
        <div class="row justify-content-center flex-row-reverse mb-7 align-items-center">
            <div class="col-lg-6 mb-lg-0 mb-4">
                <img src="/assets/food-pantry-1.png" class="img-fluid" alt="food image">
            </div>
            <div class="col-lg-6 mb-lg-0 mb-4">
                <p class="lead mb-2">
                    Our food pantry is open to all who is in need. We do ask that you register ahead of time for an accurate head count, but if that is not possible, then
                    you can do it when you arrive. Our food pantry is refilled every week with donations to help families that are in need. If you have any questions about our pantry,
                    please contact us at 845-569-8114.
                </p>

                <ul class="list-unstyled mb-0">
                    <li><i class="fas fa-check me-2"></i>Filled weekly to help families</li>
                    <li><i class="fas fa-check me-2"></i>Distributed by AME Zion Church of Newburgh</li>
                    <li><i class="fas fa-check me-2"></i>Services for adults and young children</li>
                    <li><i class="fas fa-check me-2"></i>Join us for spiritual food</li>
                </ul>
            </div>
        </div>
        <% if(foodItem != "") { %>

            <% for(i=0; i < foodItem.length; i++)  { %>
                <hr class="my-3">
                <div class="row align-items-center">
                    <div class="col-md-5 mb-3">
                        <img src="/assets/food_pantry_image.png" class="img-fluid w-100" alt="<%= foodItem[i].title %>">
                    </div>
                    <div class="col-md-7 mb-3">
                        <h4>
                            <%= foodItem[i].title %>
                        </h4>
                        <small>Posted On: <%= foodItem[i].datePosted.toLocaleString() %></small>

                        <p>
                            Beginning @ <%= foodItem[i].startTime %> to <%= foodItem[i].endTime %> <br>
                            from <%= foodItem[i].startDate %> to <%= foodItem[i].endDate %>
                        <address>
                            <%= foodItem[i].location %>
                        </address>
                        </p>
                        <p class="text-muted">
                            <%= foodItem[i].description %>
                        </p>
                        <p>
                            <strong>Email Contact:</strong>  <%= foodItem[i].contactName %> @ <%= foodItem[i].contactEmail %>
                        </p>
                        <% if(loggedIn) { %>
                            <a href="/delete/food/<%= foodItem[i]._id %>" class="btn btn-sm btn-warning">delete food item</a>
                        <% } %>
                    </div>
                </div>

            <% } %>
        <% } else { %>
            <p class="lead fw-bold">There are no events posted yet.</p>
        <% } %>
    </section>
</main>

<!-- MDB -->
<%- include('layouts/footer') -%>
</body>
</html>