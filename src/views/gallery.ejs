<!doctype html>
<html lang="en">
<%- include('layouts/head') -%>
<body>
<header>
    <%- include('layouts/navBar') -%>
</header>

<main>
    <section class="container" style="margin-top: 120px; margin-bottom: 90px;">
        <div class="row justify-content-center align-items-center">
            <div class="col-lg-12 mb-3 text-lg-start text-center">
                <h1 class="fw-bold display-4 text-info">Photos from Our church</h1>
            </div>
            <!-- show photos uploaded to uploads directory -->
            <div class="col-lg-12">
                <div class="row justify-content-center">
                    <% if(photosList != "") { %>
                        <% photosList.forEach((photo) => { %>
                            <div class="col-lg-3 col-md-6 mb-3">
                                <p class="mb-2">
                                    <% if(loggedIn) { %>
                                        <a href="/delete/images/:id" class="btn p-1 btn-warning">delete</a>
                                    <% } %>
                                    <a href="<%= photo.file %>" class="btn btn-info p-1" download="<%= photo.file %>">
                                        Download Image
                                    </a> <br>
                                </p>
                                    <img src="<%= photo.file %>" class="img-fluid" alt="Project">
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p>No photos uploaded, come back later to check.</p>
                        <div>
                            <% if(loggedIn) { %>
                                <a href="/newGallery" class="btn btn-primary rounded-pill">Upload Photos</a>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </section>
</main>

<!-- MDB -->
<%- include('layouts/footer') -%>
</body>
</html>